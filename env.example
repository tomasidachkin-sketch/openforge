# OpenForge Environment Variables

# Supabase (OpenForge's own database)
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Encryption key for storing user API keys (generate with: openssl rand -base64 32)
ENCRYPTION_KEY=your_encryption_key

# Optional: Default API keys for development/testing
# Users will provide their own keys in the app (BYOK)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
